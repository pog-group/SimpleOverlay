{
  "name": "simple-overlay",
  "productName": "Simple Overlay",
  "version": "26.0.0",
  "description": "A fullscreen transparent overlay that displays a selected URL",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.pog.simpleoverlay",
    "productName": "Simple Overlay",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "keywords": [],
  "author": {
    "name": "Spyke",
    "email": "vidal.quentin@pog-tv.com"
  },
  "license": "MIT"
}
